{
  "name": "typify",
  "displayName": "Typify",
  "publisher": "amanh",
  "description": "Interactive type inference tool powered by the Typify engine.",
  "version": "0.1.2",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": ["onLanguage:python"],
  "main": "./extension.js",
  "icon": "media/icon.png",
  "repository": {"url": "https://github.com/for-loop9/typify-vscode"},
  "contributes": {
    "commands": [
      {
        "command": "typify.showSidebar",
        "title": "Typify: Show Panel"
      },
      {
        "command": "typify.reanalyze",
        "title": "Typify: Re-analyze Project"
      },
      {
        "command": "typify.annotate",
        "title": "Annotate Symbol",
        "category": "Typify",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "editor/hover/title": [
        {
          "command": "typify.annotate",
          "when": "editorLangId == python",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "typify-container",
          "title": "Typify",
          "icon": "media/icon-dark.svg"
        }
      ]
    },
    "views": {
      "typify-container": [
        {
          "icon": "media/icon-dark.svg",
          "type": "webview",
          "id": "typify.sidebar",
          "name": "Typify"
        }
      ]
    }
  }
}